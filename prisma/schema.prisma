model Service {
  id                 Int                  @id @default(autoincrement())
  merchantId         Int
  title              String
  description        String               @db.Text
  shortDescription   String?              @db.VarChar(500)
  serviceType        String
  status             ServiceStatus        @default(DRAFT)
  category           String?
  durationMinutes    Int
  coverImageUrl      String?
  imageGallery       String[]             @default([])
  tags               String[]             @default([])
  requiresApproval   Boolean              @default(false)
  advanceBookingDays Int                  @default(30)
  cancellationHours  Int                  @default(24)
  maxBookingsPerDay  Int?
  publishedAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  merchant           Merchant             @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  pricingTiers       ServicePricingTier[]
  bookings           ServiceBooking[]
  addOns             ServiceAddOn[]
  checkIns           ServiceCheckIn[]

  @@index([merchantId, status])
  @@index([serviceType, status])
  @@index([status])
  @@index([merchantId])
  @@index([status, publishedAt])
}

model ServicePricingTier {
  id              Int              @id @default(autoincrement())
  serviceId       Int
  name            String
  description     String?
  price           Float
  durationMinutes Int
  totalSlots      Int?
  maxPerUser      Int              @default(1)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  service         Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bookings        ServiceBooking[]

  @@index([serviceId, isActive])
}

model ServiceBooking {
  id                 Int                    @id @default(autoincrement())
  serviceId          Int
  tierId             Int
  userId             Int
  merchantId         Int
  bookingDate        DateTime
  startTime          String
  endTime            String
  status             ServiceBookingStatus   @default(PENDING)
  confirmationCode   String                 @unique
  qrCode             String                 @unique
  notes              String?
  specialRequests    String?
  contactPhone       String?
  contactEmail       String?
  price              Float
  confirmedAt        DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancelledBy        Int?
  cancellationReason String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  service            Service                @relation(fields: [serviceId], references: [id])
  tier               ServicePricingTier     @relation(fields: [tierId], references: [id])
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkIns           ServiceCheckIn[]
  addOnPurchases     ServiceAddOnPurchase[]

  @@index([userId, status])
  @@index([serviceId, bookingDate])
  @@index([merchantId, bookingDate])
  @@index([merchantId, status, bookingDate])
  @@index([confirmationCode])
  @@index([qrCode])
  @@index([status])
}

model ServiceCheckIn {
  id            Int            @id @default(autoincrement())
  serviceId     Int
  bookingId     Int            @unique
  userId        Int
  checkedInAt   DateTime       @default(now())
  checkedInBy   Int?
  checkInMethod String         @default("QR_SCAN")
  notes         String?
  service       Service        @relation(fields: [serviceId], references: [id])
  booking       ServiceBooking @relation(fields: [bookingId], references: [id])

  @@index([serviceId, checkedInAt])
  @@index([userId])
}

model ServiceAddOn {
  id          Int                    @id @default(autoincrement())
  serviceId   Int
  name        String
  description String?
  price       Float
  isOptional  Boolean                @default(true)
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  service     Service                @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  purchases   ServiceAddOnPurchase[]

  @@index([serviceId, isActive])
}

model ServiceAddOnPurchase {
  id          Int            @id @default(autoincrement())
  addOnId     Int
  bookingId   Int
  userId      Int
  quantity    Int            @default(1)
  unitPrice   Float
  totalPrice  Float
  purchasedAt DateTime       @default(now())
  addOn       ServiceAddOn   @relation(fields: [addOnId], references: [id])
  booking     ServiceBooking @relation(fields: [bookingId], references: [id])
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([addOnId])
  @@index([userId])
}
