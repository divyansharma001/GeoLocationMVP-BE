generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DealCategoryMaster {
  id          Int        @id @default(autoincrement())
  name        String     @unique @db.VarChar(100)
  description String?
  icon        String?    @db.VarChar(100)
  color       String?    @db.VarChar(7)
  sortOrder   Int        @default(0)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deals       Deal[]
  merchants   Merchant[]

  @@index([active, sortOrder])
}

model DealTypeMaster {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deals       Deal[]

  @@index([active])
}

model PointEventTypeMaster {
  id          Int              @id @default(autoincrement())
  name        String           @unique @db.VarChar(50)
  description String?
  points      Int
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  pointEvents UserPointEvent[]

  @@index([active])
}

model User {
  id                    Int                       @id @default(autoincrement())
  email                 String                    @unique
  name                  String?
  password              String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  role                  UserRole                  @default(USER)
  points                Int                       @default(0)
  monthlyPoints         Int                       @default(0)
  referralCode          String?                   @unique
  referredByUserId      Int?
  birthday              DateTime?
  avatarUrl             String?
  coins                 Int                       @default(0)
  experiencePoints      Int                       @default(0)
  loyaltyTier           LoyaltyTier               @default(BRONZE)
  totalSpent            Float                     @default(0)
  emailVerifiedAt       DateTime?
  lastLoginAt           DateTime?
  bookings              Booking[]
  bountyProgress        BountyProgress[]
  checkIns              CheckIn[]
  CoinTransaction       CoinTransaction[]
  organizedEvents       Event[]                   @relation("EventOrganizer")
  eventAddOnPurchases   EventAddOnPurchase[]
  eventAttendees        EventAttendee[]           @relation("EventAttendees")
  eventCheckIns         EventCheckIn[]            @relation("EventCheckIns")
  originalEventTickets  EventTicket[]             @relation("OriginalTicketOwner")
  eventTickets          EventTicket[]             @relation("EventTickets")
  heistsAsAttacker      Heist[]                   @relation("HeistsAsAttacker")
  heistsAsVictim        Heist[]                   @relation("HeistsAsVictim")
  heistItemUsages       HeistItemUsage[]
  heistNotifications    HeistNotification[]
  heistToken            HeistToken?
  kickbackEvents        KickbackEvent[]
  kittyGamesCreated     KittyGame[]               @relation("KittyGameCreator")
  kittyGamesWon         KittyGame[]               @relation("KittyGameWinner")
  kittyGuesses          KittyGuess[]
  loyaltyTransactions   LoyaltyPointTransaction[]
  loyaltyRedemptions    LoyaltyRedemption[]
  merchant              Merchant?
  orders                Order[]
  PaymentTransaction    PaymentTransaction[]
  socialAccounts        SocialAccount[]
  referredBy            User?                     @relation("UserReferrals", fields: [referredByUserId], references: [id])
  referrals             User[]                    @relation("UserReferrals")
  UserAchievement       UserAchievement[]
  savedDeals            UserDeal[]
  heistItems            UserHeistItem[]
  loyaltyBalances       UserMerchantLoyalty[]
  userNudges            UserNudge[]
  nudgePreferences      UserNudgePreferences?
  pointEvents           UserPointEvent[]
  streak                UserStreak?
  venueRewardClaims     VenueRewardClaim[]
  checkInGameSessions   CheckInGameSession[]
  checkInGameRewards    CheckInGameIssuedReward[]
  serviceBookings       ServiceBooking[]
  serviceAddOnPurchases ServiceAddOnPurchase[]
  surpriseReveals       UserSurpriseReveal[]

  @@index([referredByUserId])
  @@index([loyaltyTier])
  @@index([totalSpent])
}

model SocialAccount {
  id             Int            @id @default(autoincrement())
  provider       SocialProvider
  providerUserId String
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  profile        Json?
  userId         Int
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId, provider])
}

model Merchant {
  id                  Int                       @id @default(autoincrement())
  businessName        String
  address             String?
  description         String?
  logoUrl             String?
  status              MerchantStatus            @default(PENDING)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  ownerId             Int                       @unique
  latitude            Float?
  longitude           Float?
  city                String?
  phoneNumber         String?
  businessType        BusinessType              @default(LOCAL)
  categoryId          Int?
  facebookUrl         String?
  galleryUrls         String[]                  @default([])
  instagramUrl        String?
  priceRange          String?
  twitterUrl          String?
  websiteUrl          String?
  amenities           String[]                  @default([])
  thingsToNote        String?
  vibeTags            String[]                  @default([])
  bookings            Booking[]
  bookingSettings     BookingSettings?
  interestLogs        BusinessInterestLog[]
  deals               Deal[]
  events              Event[]
  kickbackEvents      KickbackEvent[]
  kittyGames          KittyGame[]
  loyaltyTransactions LoyaltyPointTransaction[]
  loyaltyRedemptions  LoyaltyRedemption[]
  menuCollections     MenuCollection[]
  menuItems           MenuItem[]
  cateringItems       CateringItem[]
  category            DealCategoryMaster?       @relation(fields: [categoryId], references: [id])
  owner               User                      @relation(fields: [ownerId], references: [id])
  loyaltyProgram      MerchantLoyaltyProgram?
  verifications       MerchantVerification[]
  orders              Order[]
  stores              Store[]
  tables              Table[]
  timeSlots           TimeSlot[]
  userLoyaltyBalances UserMerchantLoyalty[]
  venueRewards        VenueReward[]
  checkInGameConfig   CheckInGameConfig?
  checkInGameSessions CheckInGameSession[]
  checkInGameRewards  CheckInGameIssuedReward[]
  services            Service[]
  blogPosts           BlogPost[]
  blogCategories      BlogCategory[]
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Deal {
  id                     Int                       @id @default(autoincrement())
  title                  String
  description            String
  discountPercentage     Int?
  discountAmount         Float?
  startTime              DateTime
  endTime                DateTime
  redemptionInstructions String
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  merchantId             Int
  recurringDays          String?
  imageUrls              String[]
  kickbackEnabled        Boolean                   @default(false)
  offerTerms             String?
  categoryId             Int
  dealTypeId             Int
  accessCode             String?
  bountyQRCode           String?
  bountyRewardAmount     Float?
  /// BOGO ("buy N get M") config — when bogoBuyQuantity is set, the deal is treated as BOGO.
  /// bogoGetDiscountPercent: 100 = free, 50 = half off, etc.
  bogoBuyQuantity        Int?
  bogoGetQuantity        Int?
  bogoGetDiscountPercent Float?
  /// Flash group bounty config — pot-based mechanic with per-person payout, slot cap, min spend.
  bountyPotAmount        Float?
  bountyMaxInvites       Int?
  bountyMinSpend         Float?
  currentRedemptions     Int                       @default(0)
  isFlashSale            Boolean                   @default(false)
  maxRedemptions         Int?
  minReferralsRequired   Int?
  isSurprise             Boolean                   @default(false)
  surpriseType           SurpriseType?
  surpriseHint           String?
  revealRadiusMeters     Int?
  revealAt               DateTime?
  revealDurationMinutes  Int?                      @default(60)
  surpriseTotalSlots     Int?
  surpriseSlotsUsed      Int                       @default(0)
  surpriseReveals        UserSurpriseReveal[]
  bountyProgress         BountyProgress[]
  checkIns               CheckIn[]
  category               DealCategoryMaster        @relation(fields: [categoryId], references: [id])
  dealType               DealTypeMaster            @relation(fields: [dealTypeId], references: [id])
  merchant               Merchant                  @relation(fields: [merchantId], references: [id])
  menuItems              DealMenuItem[]
  kickbackEvents         KickbackEvent[]
  savedByUsers           UserDeal[]
  pointEvents            UserPointEvent[]
  checkInGameRewards     CheckInGameIssuedReward[]

  @@index([accessCode])
  @@index([merchantId, dealTypeId])
  @@index([isFlashSale, endTime])
  @@index([isSurprise, surpriseType, endTime])
}

model UserDeal {
  id      Int      @id @default(autoincrement())
  userId  Int
  dealId  Int
  savedAt DateTime @default(now())
  deal    Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dealId])
}

model UserSurpriseReveal {
  id         Int       @id @default(autoincrement())
  userId     Int
  dealId     Int
  revealedAt DateTime  @default(now())
  expiresAt  DateTime
  redeemed   Boolean   @default(false)
  redeemedAt DateTime?
  deal       Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dealId])
  @@index([userId])
  @@index([dealId])
  @@index([expiresAt])
}

model UserPointEvent {
  id               Int                  @id @default(autoincrement())
  userId           Int
  dealId           Int?
  points           Int
  createdAt        DateTime             @default(now())
  pointEventTypeId Int
  deal             Deal?                @relation(fields: [dealId], references: [id])
  pointEventType   PointEventTypeMaster @relation(fields: [pointEventTypeId], references: [id])
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, pointEventTypeId])
  @@index([userId, dealId])
  @@index([createdAt])
  @@index([createdAt, userId])
  @@index([pointEventTypeId, createdAt])
}

model CheckIn {
  id              Int                 @id @default(autoincrement())
  userId          Int
  dealId          Int
  merchantId      Int
  latitude        Float
  longitude       Float
  distanceMeters  Float
  createdAt       DateTime            @default(now())
  deal            Deal                @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  miniGameSession CheckInGameSession?

  @@index([userId, dealId])
  @@index([merchantId])
  @@index([userId, createdAt])
}

model CheckInGameConfig {
  id                   Int                  @id @default(autoincrement())
  merchantId           Int                  @unique
  isEnabled            Boolean              @default(false)
  gameType             CheckInGameType      @default(SCRATCH_CARD)
  title                String               @default("Tap to win")
  subtitle             String?
  accentColor          String?
  cooldownMinutes      Int                  @default(0)
  maxPlaysPerCheckIn   Int                  @default(1)
  sessionExpiryMinutes Int                  @default(15)
  rewardExpiryHours    Int                  @default(24)
  settings             Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  merchant             Merchant             @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  rewards              CheckInGameReward[]
  sessions             CheckInGameSession[]

  @@index([isEnabled])
}

model CheckInGameReward {
  id                Int                       @id @default(autoincrement())
  configId          Int
  label             String
  description       String?
  imageUrl          String?
  rewardType        CheckInGameRewardType
  rewardValue       Float
  rewardLabel       String?
  probabilityWeight Int                       @default(1)
  isActive          Boolean                   @default(true)
  maxWins           Int?
  currentWins       Int                       @default(0)
  metadata          Json?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  config            CheckInGameConfig         @relation(fields: [configId], references: [id], onDelete: Cascade)
  sessions          CheckInGameSession[]
  issuedRewards     CheckInGameIssuedReward[]

  @@index([configId, isActive])
}

model CheckInGameSession {
  id               Int                      @id @default(autoincrement())
  sessionToken     String                   @unique
  configId         Int
  merchantId       Int
  userId           Int
  checkInId        Int                      @unique
  gameType         CheckInGameType
  status           CheckInGameSessionStatus @default(ELIGIBLE)
  expiresAt        DateTime
  playedAt         DateTime?
  resultSlot       Int?
  selectedRewardId Int?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  checkIn          CheckIn                  @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  config           CheckInGameConfig        @relation(fields: [configId], references: [id], onDelete: Cascade)
  merchant         Merchant                 @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  selectedReward   CheckInGameReward?       @relation(fields: [selectedRewardId], references: [id])
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  issuedReward     CheckInGameIssuedReward?

  @@index([userId, createdAt])
  @@index([merchantId, createdAt])
  @@index([status, expiresAt])
}

model CheckInGameIssuedReward {
  id          Int                     @id @default(autoincrement())
  sessionId   Int                     @unique
  rewardId    Int
  merchantId  Int
  userId      Int
  dealId      Int?
  rewardType  CheckInGameRewardType
  rewardValue Float
  rewardLabel String?
  imageUrl    String?
  claimCode   String                  @unique
  status      CheckInGameRewardStatus @default(AVAILABLE)
  expiresAt   DateTime?
  redeemedAt  DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  deal        Deal?                   @relation(fields: [dealId], references: [id], onDelete: SetNull)
  merchant    Merchant                @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  reward      CheckInGameReward       @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  session     CheckInGameSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([merchantId, createdAt])
  @@index([userId, status, createdAt])
}

model UserStreak {
  id                     Int       @id @default(autoincrement())
  userId                 Int       @unique
  currentStreak          Int       @default(0)
  longestStreak          Int       @default(0)
  lastCheckInDate        DateTime?
  currentWeekCheckIns    Int       @default(0)
  totalCheckIns          Int       @default(0)
  streakStartDate        DateTime?
  currentDiscountPercent Float     @default(0)
  maxDiscountReached     Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([currentStreak])
}

model City {
  id        Int      @id @default(autoincrement())
  name      String
  state     String
  active    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
  stores    Store[]

  @@unique([name, state])
  @@index([active, name])
}

model Store {
  id              Int              @id @default(autoincrement())
  merchantId      Int
  cityId          Int
  address         String
  latitude        Float?
  longitude       Float?
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  description     String?
  galleryUrls     String[]         @default([])
  isFoodTruck     Boolean          @default(false)
  operatingHours  Json?
  city            City             @relation(fields: [cityId], references: [id])
  merchant        Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  venueRewards    VenueReward[]
  menuCollections MenuCollection[]
  scheduledStops  ScheduledStop[]

  @@index([merchantId])
  @@index([cityId])
  @@index([active, cityId])
}

enum ScheduledStopStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

model ScheduledStop {
  id           Int                 @id @default(autoincrement())
  storeId      Int
  startsAt     DateTime
  endsAt       DateTime
  latitude     Float
  longitude    Float
  address      String
  notes        String?
  /// Optional override radius in meters; defaults to 200 in the API.
  radiusMeters Int?
  status       ScheduledStopStatus @default(SCHEDULED)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  store        Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([startsAt])
  @@index([storeId, startsAt])
  @@index([endsAt])
}

model MenuItem {
  id                       Int                  @id @default(autoincrement())
  merchantId               Int
  name                     String
  description              String?
  price                    Float
  category                 String
  imageUrl                 String?
  imageUrls                String[]             @default([])
  isAvailable              Boolean              @default(true)
  inventoryTrackingEnabled Boolean              @default(false)
  inventoryQuantity        Int?
  lowStockThreshold        Int?
  allowBackorder           Boolean              @default(false)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  happyHourPrice           Float?
  isHappyHour              Boolean              @default(false)
  dealType                 MenuDealType         @default(STANDARD)
  isSurprise               Boolean              @default(false)
  surpriseRevealTime       String?
  validDays                String?
  validEndTime             String?
  validStartTime           String?
  hasVariants              Boolean              @default(false)
  isBulkOrderEnabled       Boolean              @default(false)
  defaultPeopleCount       Int?
  minPeopleCount           Int?
  dealLinks                DealMenuItem[]
  collectionItems          MenuCollectionItem[]
  variants                 MenuItemVariant[]
  merchant                 Merchant             @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([merchantId, dealType])
  @@index([merchantId, isHappyHour])
  @@index([dealType])
}

model MenuItemVariant {
  id                Int      @id @default(autoincrement())
  menuItemId        Int
  sku               String   @unique
  label             String
  price             Float
  servesCount       Int?
  inventoryQuantity Int?
  lowStockThreshold Int?
  isAvailable       Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  menuItem          MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

model DealMenuItem {
  dealId            Int
  menuItemId        Int
  isHidden          Boolean  @default(false)
  assignedAt        DateTime @default(now())
  customDiscount    Float?
  customPrice       Float?
  discountAmount    Float?
  useGlobalDiscount Boolean  @default(true)
  deal              Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  menuItem          MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@id([dealId, menuItemId])
  @@index([menuItemId])
  @@index([dealId])
}

model MenuCollection {
  id          Int                  @id @default(autoincrement())
  merchantId  Int
  name        String
  description String?
  coverImageUrl String?
  servesCount Int?
  packagePrice Float?
  displayOrder Int                @default(0)
  isActive    Boolean              @default(true)
  menuType    MenuCollectionType   @default(STANDARD)
  subType     String? // e.g. DAILY, KIDS, DRINKS, DESSERTS, EARLY_MORNING, EVENING, LATE_NIGHT
  startTime   String? // Happy hour start e.g. "06:00"
  endTime     String? // Happy hour end e.g. "11:00"
  themeName   String? // For special event menus
  icon        String? // Lucide icon name for display
  color       String? // Theme color hex
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  storeId     Int?
  merchant    Merchant             @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  Store       Store?               @relation(fields: [storeId], references: [id])
  items       MenuCollectionItem[]

  @@index([merchantId])
  @@index([storeId])
  @@index([merchantId, isActive])
  @@index([merchantId, menuType])
  @@index([merchantId, displayOrder])
  @@index([name])
}

model MenuCollectionItem {
  collectionId   Int
  menuItemId     Int
  sortOrder      Int            @default(0)
  isActive       Boolean        @default(true)
  customPrice    Float?
  customDiscount Float?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  collection     MenuCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  menuItem       MenuItem       @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@id([collectionId, menuItemId])
  @@index([collectionId])
  @@index([menuItemId])
  @@index([collectionId, sortOrder])
}

// ─── Catering ────────────────────────────────────────────────────────────────
// Catering items are standalone, separate from MenuCollection/Packages.
// Each item belongs to a merchant, has per-person OR fixed pricing, a category
// label, and optional customization options (radio/checkbox groups).

enum CateringPricingType {
  PER_PERSON
  FIXED
}

model CateringItem {
  id                  Int                  @id @default(autoincrement())
  merchantId          Int
  name                String
  description         String?
  category            String
  pricePerPerson      Float                @default(0)
  fixedPrice          Float?
  pricingType         CateringPricingType  @default(PER_PERSON)
  minPeople           Int                  @default(1)
  maxPeople           Int?
  servesCount         Int?
  imageUrl            String?
  imageUrls           String[]             @default([])
  tags                String[]             @default([])
  packagingType       String?
  dietaryInfo         String[]             @default([])
  isActive            Boolean              @default(true)
  isPopular           Boolean              @default(false)
  displayOrder        Int                  @default(0)
  specialInstructions Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  merchant            Merchant             @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  options             CateringItemOption[]
  orderItems          CateringOrderItem[]

  @@index([merchantId])
  @@index([merchantId, category])
  @@index([merchantId, isActive])
  @@index([category])
  @@index([isActive, isPopular])
}

model CateringItemOption {
  id             Int                        @id @default(autoincrement())
  cateringItemId Int
  name           String
  isRequired     Boolean                    @default(false)
  minSelections  Int                        @default(0)
  maxSelections  Int                        @default(1)
  displayOrder   Int                        @default(0)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  cateringItem   CateringItem               @relation(fields: [cateringItemId], references: [id], onDelete: Cascade)
  choices        CateringItemOptionChoice[]

  @@index([cateringItemId])
  @@index([cateringItemId, displayOrder])
}

model CateringItemOptionChoice {
  id            Int                @id @default(autoincrement())
  optionId      Int
  label         String
  description   String?
  priceModifier Float              @default(0)
  isDefault     Boolean            @default(false)
  isPopular     Boolean            @default(false)
  displayOrder  Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  option        CateringItemOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@index([optionId])
  @@index([optionId, displayOrder])
}

model CateringOrderItem {
  id                  Int          @id @default(autoincrement())
  orderId             Int
  cateringItemId      Int
  quantity            Int
  pricePerUnit        Float
  totalPrice          Float
  specialInstructions String?
  /// Snapshot of selected options at order time, e.g.
  /// [{ optionId, optionName, choices: [{ choiceId, label, priceModifier }] }]
  selectedOptions     Json?
  createdAt           DateTime     @default(now())
  order               Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cateringItem        CateringItem @relation(fields: [cateringItemId], references: [id])

  @@index([orderId])
  @@index([cateringItemId])
}

model KickbackEvent {
  id                Int      @id @default(autoincrement())
  merchantId        Int
  dealId            Int
  userId            Int
  amountEarned      Float
  sourceAmountSpent Float
  inviteeCount      Int      @default(1)
  createdAt         DateTime @default(now())
  deal              Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  merchant          Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([merchantId, createdAt])
  @@index([userId])
  @@index([dealId])
  @@index([userId, createdAt])
}

model Table {
  id         Int         @id @default(autoincrement())
  merchantId Int
  name       String
  capacity   Int
  features   String[]
  status     TableStatus @default(AVAILABLE)
  createdAt  DateTime    @default(now())
