model BlogCategory {
  id          Int        @id @default(autoincrement())
  merchantId  Int
  name        String     @db.VarChar(100)
  slug        String     @db.VarChar(120)
  description String?
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
