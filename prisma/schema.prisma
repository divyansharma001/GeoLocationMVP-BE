  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
}

model BountyProgress {
  id              Int       @id @default(autoincrement())
  userId          Int
  dealId          Int
  referralCount   Int       @default(0)
  rewardsEarned   Float     @default(0)
  isCompleted     Boolean   @default(false)
  completedAt     DateTime?
  qrCodeScannedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deal            Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dealId])
  @@index([userId])
  @@index([dealId])
  @@index([isCompleted])
}

model KittyGame {
  id               Int             @id @default(autoincrement())
  merchantId       Int
  title            String          @db.VarChar(200)
  prizePool        Float           @default(0)
  entryFee         Int             @default(10)
  secretValue      Float?
  guessWindowStart DateTime
  guessWindowEnd   DateTime
  status           KittyGameStatus @default(PENDING)
  winnerId         Int?
  winnerGuessId    Int?
  minPlayers       Int             @default(2)
  maxPlayers       Int?
  createdBy        Int
  resolvedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  creator          User            @relation("KittyGameCreator", fields: [createdBy], references: [id])
  merchant         Merchant        @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  winner           User?           @relation("KittyGameWinner", fields: [winnerId], references: [id])
  guesses          KittyGuess[]

  @@index([merchantId, status])
  @@index([status])
  @@index([guessWindowEnd])
  @@index([winnerId])
}

model KittyGuess {
  id         Int       @id @default(autoincrement())
  gameId     Int
  userId     Int
  guessValue Float
  coinsSpent Int       @default(0)
  isWinner   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  game       KittyGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
  @@index([isWinner])
}

model VenueReward {
  id                   Int                @id @default(autoincrement())
  merchantId           Int
  storeId              Int?
  title                String             @db.VarChar(200)
  description          String?
  rewardType           VenueRewardType    @default(COINS)
  rewardAmount         Float
  geoFenceRadiusMeters Int                @default(100)
  latitude             Float?
  longitude            Float?
  status               VenueRewardStatus  @default(DRAFT)
  startDate            DateTime
  endDate              DateTime
  maxTotalClaims       Int?
  currentClaims        Int                @default(0)
  maxClaimsPerUser     Int                @default(1)
  cooldownHours        Int                @default(24)
  requiresCheckIn      Boolean            @default(true)
  isVerifiedOnly       Boolean            @default(true)
  imageUrl             String?
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  merchant             Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  store                Store?             @relation(fields: [storeId], references: [id])
  claims               VenueRewardClaim[]

  @@index([merchantId, status])
  @@index([status, startDate, endDate])
  @@index([merchantId, storeId])
}

model VenueRewardClaim {
  id                 Int                     @id @default(autoincrement())
  venueRewardId      Int
  userId             Int
  claimLatitude      Float
  claimLongitude     Float
  distanceMeters     Float
  verificationMethod ClaimVerificationMethod @default(GPS)
  coinsAwarded       Int                     @default(0)
  pointsAwarded      Int                     @default(0)
  rewardValue        Float
  metadata           Json?
  createdAt          DateTime                @default(now())
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  venueReward        VenueReward             @relation(fields: [venueRewardId], references: [id], onDelete: Cascade)

  @@index([userId, venueRewardId, createdAt])
  @@index([venueRewardId, createdAt])
}

model MerchantVerification {
  id              Int                  @id @default(autoincrement())
  merchantId      Int
  stepType        VerificationStepType
  status          VerificationStatus   @default(PENDING)
  documentUrl     String?
  documentType    String?              @db.VarChar(100)
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewedBy      Int?
  rejectionReason String?
  notes           String?
  metadata        Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  merchant        Merchant             @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, stepType])
  @@index([merchantId, status])
  @@index([status])
}

model BusinessInterestLog {
